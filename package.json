{
  "name": "claude-dashboard",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev --port 19280 --hostname 127.0.0.1",
    "ensure-sqlite-binding": "node -e \"process.exit(require('fs').existsSync('node_modules/better-sqlite3/build/Release/better_sqlite3.node')?0:1)\" || npm rebuild better-sqlite3",
    "build": "npm run ensure-sqlite-binding && next build && node scripts/postbuild.mjs",
    "start": "node server.mjs",
    "test": "npx playwright test",
    "test:e2e": "npx playwright test --reporter=list"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "gray-matter": "^4.0.3",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  }
}
